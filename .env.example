# ── Required ──────────────────────────────────────────────────────────────────
# JWT signing secret for host/admin accounts. Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-strong-random-string-at-least-32-chars

# ── Core (defaults shown) ─────────────────────────────────────────────────────
# MONGO_URI=mongodb://mongo:27017/rundan
# PORT=5000
# NODE_ENV=production
# FRONTEND_URL=https://rundan.example.com   # Used for CORS in production (comma-separated for several)
# ACCESS_TOKEN_EXPIRES_IN=15m
# APP_NAME=Rundan

# ── Super-admins ──────────────────────────────────────────────────────────────
# Accounts whose email is listed here become super-admin (manage every event) on
# their next login. ';'-separated for several. This is also the recovery path if
# all admin accounts are lost — just add an email here and re-login.
# ADMIN_EMAILS=you@example.com;cohost@example.com

# ── Production behind Cloudflare + Traefik (docker-compose.prod.yml) ──────────
# RUNDAN_HOST=rundan.yourdomain.com        # the public hostname Traefik routes
# TRAEFIK_NETWORK=web                       # your existing external Traefik network
# TRAEFIK_ENTRYPOINT=websecure              # Traefik entrypoint (web | websecure)
# TRAEFIK_TLS=true                          # true if Traefik terminates TLS
# TRAEFIK_CERTRESOLVER=                     # only if Traefik (not a CF origin cert) issues certs
# Trusted proxy hops so req.ip/rate-limits see the real client:
# Cloudflare → Traefik → nginx = 3.
# TRUST_PROXY=3

# ── Optional site gate (private/family deployments) ───────────────────────────
# A shared site password gating the whole API + socket. Empty = open (no gate).
# Mirrors rundan's access code; timing-safe compared.
# ACCESS_CODE=

# Typed confirmation code for the destructive clean-and-seed wipe (second factor
# behind an admin account). Override in production.
# SEED_CODE=CALLE

# Seed sample demo data on startup when the DB is empty.
# SEED_ON_STARTUP=false

# ── Spotify (optional — music quiz auto-fill + in-browser playback) ───────────
# Public client id used by the browser PKCE login (safe to expose to the SPA).
# SPOTIFY_CLIENT_ID=
# Server-side client secret (only if you use the confidential token exchange).
# SPOTIFY_CLIENT_SECRET=

# ── Last.fm (optional — "similar artist" distractors for music quiz) ──────────
# LASTFM_API_KEY=

# ── Web Push (optional — event notifications) ─────────────────────────────────
# Generate a keypair with:  npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# ── Mailgun (optional — host email: verify / reset / magic-link) ──────────────
# Without it those endpoints no-op; username+password admin still works.
# MAILGUN_DOMAIN is your Mailgun sending domain; EMAIL_FROM must be on it.
# Set MAILGUN_API_BASE to https://api.eu.mailgun.net for an EU-region domain.
# MAILGUN_API_KEY=...
# MAILGUN_DOMAIN=mg.jeklund.dev
# MAILGUN_API_BASE=https://api.mailgun.net
# EMAIL_FROM=Rundan <noreply@jeklund.dev>

# ── Uploads ───────────────────────────────────────────────────────────────────
# Directory for admin/player image uploads (served at /uploads). Defaults to
# ./uploads next to the backend, or $HOME/data/uploads when HOME is set.
# UPLOADS_DIR=
